{
  "name": "components-kit-react",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/components-kit/components-kit-react.git"
  },
  "main": "lib/esm/index.js",
  "exports": {
    ".": {
      "require": "./lib/index.js",
      "import": "./lib/esm/index.js"
    }
  },
  "author": "Components Kit",
  "license": "MIT",
  "description": "A collection of React components for Components Kit",
  "keywords": [
    "react",
    "components",
    "ui",
    "kit"
  ],
  "homepage": "https://componentskit.com",
  "bugs": {
    "url": "https://github.com/components-kit/components-kit-react/issues"
  },
  "scripts": {
    "test": "jest --config jestconfig.json",
    "build": "yarn build:esm && yarn build:cjs && copyfiles -u 1 src/**/*.css lib",
    "build:esm": "tsc --module esnext && copyfiles -u 1 src/**/*.css lib/esm",
    "build:cjs": "tsc --module commonjs --outDir lib/cjs && copyfiles -u 1 src/**/*.css lib/cjs",
    "format": "prettier --write \"src/**/*.tsx\"",
    "lint": "eslint \"src/**\"",
    "prepare": "yarn run build",
    "prepublishOnly": "yarn run lint",
    "preversion": "yarn run lint",
    "version": "yarn run format && git add -A src",
    "postversion": "git push && git push --tags"
  },
  "dependencies": {
    "classnames": "^2.3.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.3.0",
    "@commitlint/config-conventional": "^17.3.0",
    "@types/react": "^18.2.8",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "copyfiles": "^2.4.1",
    "eslint": "^8.0.1",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^4.0.0",
    "husky": "^8.0.2",
    "jest": "^29.5.0",
    "lint-staged": "^13.1.0",
    "prettier": "^2.3.2",
    "react": "^16.0.0",
    "react-dom": "^16.0.0",
    "source-map-support": "^0.5.20",
    "supertest": "^6.1.3",
    "ts-jest": "^27.0.3",
    "ts-loader": "^9.2.3",
    "ts-node": "^10.0.0",
    "tsconfig-paths": "^3.10.1",
    "typescript": "^4.3.5"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "lint-staged": {
    "*.{ts, js}": "yarn lint"
  }
}
